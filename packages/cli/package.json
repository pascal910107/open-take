{
  "name": "open-take",
  "version": "0.1.3",
  "description": "Agent-native demo recorder \u2014 your agent explores the app, records, and renders a cinematic demo; you refine by asking it for changes.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "open-take": "./dist/cli.js"
  },
  "files": [
    "dist",
    "skill"
  ],
  "scripts": {
    "build": "tsdown && node scripts/copy-skill.mjs && node scripts/copy-readme.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx/esm test/*.test.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@open-take/runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "tsdown": "^0.9.0",
    "tsx": "^4.22.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "demo",
    "screen-recording",
    "video",
    "agent",
    "cdp",
    "screencast"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pascal910107/open-take.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/pascal910107/open-take#readme",
  "bugs": {
    "url": "https://github.com/pascal910107/open-take/issues"
  }
}
